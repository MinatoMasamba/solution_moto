# Copier ce fichier en .env et adapter les valeurs.

# dev en local ; mettre "prod" sur le serveur (PythonAnywhere, etc.)
DJANGO_ENV=dev

SECRET_KEY=change-me-in-production
DEBUG=True

# En prod, mettre le(s) domaine(s), ex:
# ALLOWED_HOSTS=sourceacademique.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Laisser vide en local pour utiliser SQLite, sinon:
# postgres://go_mboka:go_mboka@db:5432/go_mboka
DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:3000

NPM_BIN_PATH=npm
